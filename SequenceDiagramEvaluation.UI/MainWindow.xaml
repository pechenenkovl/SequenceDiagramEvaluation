<Window x:Class="SequenceDiagramEvaluation.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SequenceDiagramEvaluation.UI"
        mc:Ignorable="d"
        Title="Sequence Diagram Evaluation" Height="600" Width="1000">
    <Window.Resources>
        <!-- Style for highlighting split rows -->
        <Style x:Key="HighlightRowStyle" TargetType="DataGridRow">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsSplitRow}" Value="True">
                    <Setter Property="Background" Value="#FFFFCC"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- File Selection -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="SelectFileButton" Content="Select LaTeX ZIP File" 
                    Click="SelectFileButton_Click" 
                    Padding="15,8" FontSize="14"/>
            <TextBlock x:Name="SelectedFileText" Text="No file selected" 
                       VerticalAlignment="Center" Margin="15,0,0,0" 
                       FontSize="14" Foreground="Gray"/>
        </StackPanel>

        <!-- Options -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <CheckBox x:Name="SplitMessagesCheckBox" Content="Split messages if there is no blocks" 
                      VerticalAlignment="Center" FontSize="14"
                      Checked="SplitMessagesCheckBox_Changed" Unchecked="SplitMessagesCheckBox_Changed"/>
        </StackPanel>

        <!-- Metrics DataGrid -->
        <DataGrid x:Name="ResultsGrid" Grid.Row="2" AutoGenerateColumns="False" 
                  IsReadOnly="True" CanUserAddRows="False" Margin="0,0,0,10"
                  RowStyle="{StaticResource HighlightRowStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Diagram" Binding="{Binding DiagramName}" Width="*"/>
                <DataGridTextColumn Header="Number of objects" Binding="{Binding ParticipantScore}" Width="Auto"/>
                <DataGridTextColumn Header="Number of messages in the main block" Binding="{Binding MainBlockMessageScore}" Width="Auto"/>
                <DataGridTextColumn Header="Number of blocks" Binding="{Binding FirstLevelBlockCount}" Width="Auto"/>
                <DataGridTextColumn Header="Avg messages within a block" Binding="{Binding AverageMessagesFormatted}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Ratings Section Header -->
        <TextBlock Grid.Row="3" Text="Evaluation Ratings (1-10)" FontWeight="Bold" FontSize="14" Margin="0,10,0,5"/>

        <!-- Ratings DataGrid -->
        <DataGrid x:Name="RatingsGrid" Grid.Row="4" AutoGenerateColumns="False" 
                  IsReadOnly="True" CanUserAddRows="False"
                  RowStyle="{StaticResource HighlightRowStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Diagram" Binding="{Binding DiagramName}" Width="*"/>
                <DataGridTextColumn Header="Objects Rating" Binding="{Binding ObjectsRating}" Width="Auto"/>
                <DataGridTextColumn Header="Main Messages Rating" Binding="{Binding MainBlockMessagesRating}" Width="Auto"/>
                <DataGridTextColumn Header="Blocks Rating" Binding="{Binding BlocksRating}" Width="Auto"/>
                <DataGridTextColumn Header="Avg Messages Rating" Binding="{Binding AverageMessagesRating}" Width="Auto"/>
                <DataGridTextColumn Header="Average" Binding="{Binding OverallAverageFormatted}" Width="Auto"/>
                <DataGridTextColumn Header="Scale" Binding="{Binding Scale}" Width="Auto"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>
